{:paths ["cljc/src"]
 ;; real git pins (the old org.kotoba-lang/* group + :local/root pair was never
 ;; resolvable as a git dep — monorepo-layout-only). Workspace-offline dev
 ;; against sibling checkouts: use the :dev alias.
 :deps {io.github.kotoba-lang/num {:git/sha "0561213834f144c7c9f912217e63225ec589467a"}
        io.github.kotoba-lang/torch {:git/sha "e986ef3047375cd9d657018b6377a08c28745a30"}}
 :aliases
 {:dev {:override-deps {io.github.kotoba-lang/num {:local/root "../num"}
                        io.github.kotoba-lang/torch {:local/root "../torch"}}}
  :test {:extra-paths ["cljc/test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner" "-d" "cljc/test"]
         :exec-fn cognitect.test-runner.api/test}
  :verify-shard {:extra-paths ["verify"]
                 :main-opts ["-m" "kotodama.verify.gemma4-e4b-shard"]}
  :verify-maturity {:extra-paths ["verify"]
                    :main-opts ["-m" "kotodama.verify.maturity"]}
  :verify-maturity-run {:extra-paths ["verify"]
                        :main-opts ["-m" "kotodama.verify.run-maturity"]}
  :verify-torch-num {:extra-paths ["verify"]
                     :main-opts ["-m" "kotodama.verify.torch-num-smoke"]}
  :cljs-wasm-smoke {:extra-paths ["verify"]
                    :extra-deps {org.clojure/clojurescript {:mvn/version "1.11.132"}}
                    :main-opts ["-m" "cljs.main"
                                "-co" "{:optimizations :simple :target :nodejs :main kotodama.verify.cljs-wasm-smoke :output-to \"target/kotodama-cljs-wasm-smoke.js\"}"
                                "-c" "kotodama.verify.cljs-wasm-smoke"]}
  :verify-gguf {:extra-paths ["verify"]
                :main-opts ["-m" "kotodama.verify.gemma4-e4b-gguf"]}
  :verify-gemma-num {:extra-paths ["verify"]
                     :main-opts ["-m" "kotodama.verify.gemma4-e4b-num-smoke"]}
  :verify-ollama {:extra-paths ["verify"]
                  :main-opts ["-m" "kotodama.verify.gemma4-e4b-ollama"]}
  :verify-gemma-generate {:extra-paths ["verify"]
                          :main-opts ["-m" "kotodama.verify.gemma4-e4b-generate-smoke"]}
  :verify-gemma-ple-generate {:extra-paths ["verify"]
                              ;; CACHE_WEIGHTS=1 materializes roughly 20 GiB of
                              ;; dequantized weights; the default JVM heap dies
                              ;; before the first real-model token.
                              :jvm-opts ["-Xmx24g"]
                              :main-opts ["-m" "kotodama.verify.gemma4-e4b-ple-generate-smoke"]}
  :verify-gemma-kvcache {:extra-paths ["verify"]
                         :main-opts ["-m" "kotodama.verify.gemma4-kvcache-smoke"]}}}
